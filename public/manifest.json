{
  "manifest_version": 3,
  "name": "퀵링크",
  "description": "우측 패널에서 그룹별 바로가기 링크를 관리하는 Chrome 확장 프로그램.",
  "version": "0.1.0",
  "permissions": [
    "sidePanel"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "퀵링크 패널 토글",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "index.html"
  }
}

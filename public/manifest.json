{
  "manifest_version": 3,
  "name": "Quick Link",
  "description": "Chrome extension for creating, searching, and managing bookmarks in groups.",
  "version": "0.1.0",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Quick Link panel",
    "default_icon": {
      "16": "icons/icon_16x16.png",
      "32": "icons/icon_32x32.png"
    }
  },
  "icons": {
    "16": "icons/icon_16x16.png",
    "32": "icons/icon_32x32.png",
    "64": "icons/icon_64x64.png",
    "128": "icons/icon_128x128.png"
  },
  "side_panel": {
    "default_path": "index.html"
  }
}

{
  "manifest_version": 3,
  "name": "퀵링크",
  "description": "우측 패널에서 그룹과 링크를 생성, 검색, 수정, 삭제할 수 있는 Chrome 확장 프로그램.",
  "version": "0.1.0",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "퀵링크 패널 토글",
    "default_icon": {
      "16": "icons/icon_16x16.png",
      "32": "icons/icon_32x32.png"
    }
  },
  "icons": {
    "16": "icons/icon_16x16.png",
    "32": "icons/icon_32x32.png",
    "64": "icons/icon_64x64.png",
    "128": "icons/icon_128x128.png"
  },
  "side_panel": {
    "default_path": "index.html"
  }
}
